---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import SectionLabel from "../../components/SectionLabel.astro";
import Panel from "../../components/Panel.astro";

const work = (await getCollection("work")).sort(
  (a, b) => b.data.year - a.data.year || a.data.title.localeCompare(b.data.title),
);
---

<Layout title="Work">
  <div class="page-shell">
    <SectionLabel code="WRK-001" label="Work" />

    <div class="work-grid">
      {
        work.map((entry, index) => (
          <Panel
            title={entry.data.title}
            meta={`${entry.data.role} · ${entry.data.year}`}
            href={`/work/${entry.id}`}
            span={entry.data.gridSpan}
            offset={index === 1}
          />
        ))
      }
    </div>
  </div>
</Layout>
