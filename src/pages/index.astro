---
import Layout from "../layouts/Layout.astro";

const links = [
  { href: "#", label: "Music" },
  { href: "#", label: "Work" },
  { href: "#", label: "About" },
];
---

<Layout>
  <main class="relative flex h-dvh flex-col items-center justify-center px-6">
    <nav
      class="absolute inset-x-0 top-0 flex justify-center gap-8 px-6 py-8"
      aria-label="Primary"
    >
      {
        links.map(({ href, label }) => (
          <a
            href={href}
            class="font-mono text-xs tracking-widest text-[var(--muted)] uppercase transition-colors hover:text-[var(--text)]"
          >
            {label}
          </a>
        ))
      }
    </nav>

    <h1
      class="text-[clamp(3rem,12vw,7rem)] leading-none font-medium tracking-[-0.04em] text-[var(--text)]"
    >
      muuz.is
    </h1>
  </main>
</Layout>
