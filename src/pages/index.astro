---
import Layout from "../layouts/Layout.astro";
import Panel from "../components/Panel.astro";
---

<Layout mainClass="min-h-dvh">
  <section
    class="flex min-h-[70dvh] flex-col items-center justify-center px-6 pt-[var(--spacing-nav)]"
  >
    <h1 class="hero-wordmark text-display-xl font-medium text-[var(--text)]">
      muuz.is
    </h1>
  </section>

  <section class="page-shell border-t border-[var(--color-border)] pt-16">
    <div class="mb-10 flex items-baseline justify-between gap-4">
      <div>
        <p class="section-label mb-2">Featured</p>
        <h2 class="section-title">Selected work</h2>
      </div>
      <a
        href="/work"
        class="font-mono text-xs tracking-widest text-[var(--muted)] uppercase transition-colors hover:text-[var(--text)]"
      >
        View all →
      </a>
    </div>

    <div class="work-grid">
      <Panel
        title="MG Bootcamp"
        meta="Web · 2025"
        href="/work"
        span="large"
      />
      <Panel
        title="RAW 26"
        meta="Sound design · 2026"
        href="/work"
        span="default"
        offset
      />
    </div>
  </section>
</Layout>
