---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import SectionLabel from "../../components/SectionLabel.astro";
import Panel from "../../components/Panel.astro";

const music = (await getCollection("music")).sort(
  (a, b) => b.data.year - a.data.year || a.data.title.localeCompare(b.data.title),
);

function musicMeta(entry: (typeof music)[number]) {
  const { format, year } = entry.data;
  return format ? `${format} · ${year}` : String(year);
}
---

<Layout title="Music">
  <div class="page-shell">
    <SectionLabel code="MUS-001" label="Music" />

    <div class="work-grid">
      {
        music.map((entry, index) => (
          <Panel
            title={entry.data.title}
            meta={musicMeta(entry)}
            href={`/music/${entry.id}`}
            span={entry.data.gridSpan}
            offset={index === 1}
          />
        ))
      }
    </div>
  </div>
</Layout>
