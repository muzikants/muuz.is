---
const links = [
  { href: "/music", label: "Music" },
  { href: "/work", label: "Work" },
  { href: "/about", label: "About" },
];

const pathname = Astro.url.pathname;

function isActive(href: string) {
  return pathname === href || pathname.startsWith(`${href}/`);
}
---

<header
  class="fixed inset-x-0 top-0 z-10 border-b border-[var(--color-border)] bg-[var(--bg)]/85 backdrop-blur-sm"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4"
    aria-label="Primary"
  >
    <a
      href="/"
      class:list={[
        "font-mono text-sm tracking-[0.2em] uppercase transition-opacity hover:opacity-70",
        pathname === "/" ? "text-[var(--text)]" : "text-[var(--muted)]",
      ]}
    >
      muuz.is
    </a>
    <ul class="flex gap-8">
      {
        links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              aria-current={isActive(href) ? "page" : undefined}
              class:list={[
                "font-mono text-xs tracking-widest uppercase transition-colors",
                isActive(href)
                  ? "text-[var(--text)]"
                  : "text-[var(--muted)] hover:text-[var(--text)]",
              ]}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
