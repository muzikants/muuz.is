---
const links = [
  { label: "SoundCloud", href: "https://soundcloud.com/muuzis" },
  {
    label: "Spotify",
    href: "https://open.spotify.com/artist/6g0aXENYFr0qfxoLxPibhT",
  },
  { label: "Bandcamp", href: "https://muuzis.bandcamp.com/" },
  { label: "Instagram", href: "https://www.instagram.com/_muuzis/" },
  { label: "YouTube", href: "https://www.youtube.com/@muuzis" },
];
---

<ul class="flex flex-col gap-4">
  {
    links.map(({ label, href }) => (
      <li>
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-baseline gap-4"
        >
          <span class="font-mono text-xs tracking-[0.2em] text-[var(--muted)] uppercase transition-colors group-hover:text-[var(--text)]">
            {label}
          </span>
          <span class="h-px w-8 bg-[var(--color-border)] transition-colors group-hover:bg-[var(--text)]" />
        </a>
      </li>
    ))
  }
</ul>
